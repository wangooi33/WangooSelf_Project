# *** Counter Settings ***
TIM8.Prescaler=((TIM_CLOCK_DIVIDER) - 1)
TIM8.CounterMode=TIM_COUNTERMODE_CENTERALIGNED1
TIM8.Period=((PWM_PERIOD_CYCLES) / 2)
TIM8.ClockDivision=TIM_CLOCKDIVISION_DIV2
TIM8.RepetitionCounter=(REP_COUNTER)
TIM8.AutoReloadPreload=TIM_AUTORELOAD_PRELOAD_DISABLE


# *** Trigger Output (TRGO) Parameters ***
TIM8.TIM_MasterSlaveMode=TIM_MASTERSLAVEMODE_DISABLE
TIM8.TIM_MasterOutputTrigger=TIM_TRGO_RESET


# *** BRK Configuration ***
TIM8.BreakState=TIM_BREAK_DISABLE
TIM8.BreakPolarity=TIM_BREAKPOLARITY_LOW


# *** Break And Dead Time management - Output Configuration ***
TIM8.AutomaticOutput=TIM_AUTOMATICOUTPUT_DISABLE
TIM8.OffStateRunMode=TIM_OSSR_ENABLE
TIM8.OffStateIDLEMode=TIM_OSSI_ENABLE
TIM8.LockLevel=TIM_LOCKLEVEL_OFF


# *** Clear Input ***
TIM8.ClearInputSource=TIM_CLEARINPUTSOURCE_NONE

TIM8.DeadTime=((DEAD_TIME_COUNTS) / 2)

# *** PWM Generation Channel 1 ***
TIM8.Channel-PWM\ Generation1\ CH1\ CH1N=TIM_CHANNEL_1
TIM8.OCMode_PWM-PWM\ Generation1\ CH1\ CH1N=TIM_OCMODE_PWM1
TIM8.OC1Preload_PWM=ENABLE
TIM8.OCIdleState_1=TIM_OCIDLESTATE_RESET
TIM8.OCPolarity_1=TIM_OCPOLARITY_HIGH

# *** PWM Generation Channel LS_PWM CH1N ***
TIM8.OCNPolarity_1=TIM_OCNPOLARITY_HIGH
TIM8.OCNIdleState_1=TIM_OCNIDLESTATE_RESET
TIM8.Pulse-PWM\ Generation1\ CH1\ CH1N=((PWM_PERIOD_CYCLES) / 4)

# *** PWM Generation Channel 2 ***
TIM8.Channel-PWM\ Generation2\ CH2\ CH2N=TIM_CHANNEL_2
TIM8.OCMode_PWM-PWM\ Generation2\ CH2\ CH2N=TIM_OCMODE_PWM1
TIM8.OC2Preload_PWM=ENABLE
TIM8.OCIdleState_2=TIM_OCIDLESTATE_RESET
TIM8.OCPolarity_2=TIM_OCPOLARITY_HIGH

# *** PWM Generation Channel LS_PWM CH2N ***
TIM8.OCNPolarity_2=TIM_OCNPOLARITY_HIGH
TIM8.OCNIdleState_2=TIM_OCNIDLESTATE_RESET
TIM8.Pulse-PWM\ Generation2\ CH2\ CH2N=((PWM_PERIOD_CYCLES) / 4)

# *** PWM Generation Channel 3 ***
TIM8.Channel-PWM\ Generation3\ CH3\ CH3N=TIM_CHANNEL_3
TIM8.OCMode_PWM-PWM\ Generation3\ CH3\ CH3N=TIM_OCMODE_PWM1
TIM8.OC3Preload_PWM=ENABLE
TIM8.OCIdleState_3=TIM_OCIDLESTATE_RESET
TIM8.OCPolarity_3=TIM_OCPOLARITY_HIGH

# *** PWM Generation Channel LS_PWM CH3N ***
TIM8.OCNPolarity_3=TIM_OCNPOLARITY_HIGH
TIM8.OCNIdleState_3=TIM_OCNIDLESTATE_RESET
TIM8.Pulse-PWM\ Generation3\ CH3\ CH3N=((PWM_PERIOD_CYCLES) / 4)

# *** PWM Generation Channel 4 ***
TIM8.Channel-PWM\ Generation4\ No\ Output=TIM_CHANNEL_4
TIM8.OCMode_PWM-PWM\ Generation4\ No\ Output=TIM_OCMODE_PWM2
TIM8.OC4Preload_PWM=ENABLE
TIM8.OCPolarity_4=TIM_OCPOLARITY_HIGH
TIM8.OCIdleState_4=TIM_OCIDLESTATE_RESET

TIM8.Pulse-PWM\ Generation4\ No\ Output=(((PWM_PERIOD_CYCLES) / 2) - (HTMIN))
VP_TIM8_VS_no_output4.Mode=PWM Generation4 No Output
VP_TIM8_VS_no_output4.Signal=TIM8_VS_no_output4

TIM8.IPParameters=CounterMode,ClockDivision,AutoReloadPreload,TIM_MasterSlaveMode,TIM_MasterOutputTrigger,BreakState,BreakPolarity,AutomaticOutput,OffStateRunMode,OffStateIDLEMode,LockLevel,ClearInputSource,Channel-PWM\ Generation1\ CH1\ CH1N,OCMode_PWM-PWM\ Generation1\ CH1\ CH1N,OC1Preload_PWM,OCIdleState_1,OCPolarity_1,OCNPolarity_1,OCNIdleState_1,Channel-PWM\ Generation2\ CH2\ CH2N,OCMode_PWM-PWM\ Generation2\ CH2\ CH2N,OC2Preload_PWM,OCIdleState_2,OCPolarity_2,OCNPolarity_2,OCNIdleState_2,Channel-PWM\ Generation3\ CH3\ CH3N,OCMode_PWM-PWM\ Generation3\ CH3\ CH3N,OC3Preload_PWM,OCIdleState_3,OCPolarity_3,OCNPolarity_3,OCNIdleState_3,Channel-PWM\ Generation4\ No\ Output,OCMode_PWM-PWM\ Generation4\ No\ Output,OC4Preload_PWM,OCPolarity_4,OCIdleState_4,Prescaler,Period,RepetitionCounter,DeadTime,Pulse-PWM\ Generation1\ CH1\ CH1N,Pulse-PWM\ Generation2\ CH2\ CH2N,Pulse-PWM\ Generation3\ CH3\ CH3N,Pulse-PWM\ Generation4\ No\ Output
